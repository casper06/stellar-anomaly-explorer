# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright transient output
/test-results/
/playwright-report/
# Visual-verification captures (regenerate via e2e/tooltip-screenshots.spec.ts)
e2e/screenshots/

# extracted engine package (own install + build output)
packages/*/node_modules/
packages/*/dist/

# Claude Code local config (model preference + machine-specific permission
# allowlist with absolute paths) — personal, not shared project config
.claude/

# Local planning docs (personal, not shared project config)
STELLAR_ANOMALY_EXPLORER_LONGTERM_ROADMAP.md
STELLAR_ANOMALY_EXPLORER_PLAN.md
