{
  "name": "stellar-anomaly-explorer",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:routes && npm run test:engine",
    "test:unit": "node --import ./scripts/register-ts-resolver.mjs --test src/lib/__tests__/*.unit.test.ts",
    "test:routes": "node --import ./scripts/register-route-test-resolver.mjs --test src/app/api/__tests__/*.route.test.ts",
    "test:engine": "npm --prefix packages/stellar-vetting-engine test",
    "test:data": "npm --prefix packages/stellar-vetting-engine run test:data",
    "test:external-health": "node --import ./scripts/register-ts-resolver.mjs scripts/external-health.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/three": "^0.185.0",
    "axios": "^1.18.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
